<Application x:Class="BatmanSuitJsonBuilder.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Dark" />
                <ui:ControlsDictionary />
            </ResourceDictionary.MergedDictionaries>

            <!-- WPF UI beta skin: keep the Fluent control base, then layer our clean WayneTech colors over it. -->
            <Color x:Key="Bg0">#06101B</Color>
            <Color x:Key="Bg1">#0B1B2B</Color>
            <Color x:Key="Bg2">#102A40</Color>
            <Color x:Key="Bg3">#163A58</Color>
            <Color x:Key="Line0">#1B9ED8</Color>
            <Color x:Key="Line1">#67DFFF</Color>
            <Color x:Key="Accent0">#FFC928</Color>
            <Color x:Key="Accent1">#FFE889</Color>
            <Color x:Key="Text0">#FFFFFF</Color>
            <Color x:Key="Text1">#D8EEFF</Color>
            <Color x:Key="Text2">#8FB7D3</Color>

            <SolidColorBrush x:Key="WindowBrush" Color="{StaticResource Bg0}"/>
            <SolidColorBrush x:Key="PanelBrush" Color="{StaticResource Bg1}"/>
            <SolidColorBrush x:Key="PanelBrush2" Color="{StaticResource Bg2}"/>
            <SolidColorBrush x:Key="PanelBrush3" Color="{StaticResource Bg3}"/>
            <SolidColorBrush x:Key="LineBrush" Color="{StaticResource Line0}"/>
            <SolidColorBrush x:Key="LineBrush2" Color="{StaticResource Line1}"/>
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent0}"/>
            <SolidColorBrush x:Key="AccentBrush2" Color="{StaticResource Accent1}"/>
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource Text0}"/>
            <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource Text1}"/>
            <SolidColorBrush x:Key="DimTextBrush" Color="{StaticResource Text2}"/>

            <!-- Embedded font hook. If Assets/Fonts/DIN Condensed Bold.ttf is present at build time, MSBuild embeds it into the EXE as a WPF Resource. -->
            <FontFamily x:Key="GameFontFamily">pack://application:,,,/Assets/Fonts/#DIN Condensed Bold, pack://application:,,,/Assets/Fonts/#DIN Condensed, DIN Condensed Bold, DIN Condensed, Bahnschrift Condensed, Agency FB, Segoe UI Variable, Segoe UI</FontFamily>

            <LinearGradientBrush x:Key="AppBackground" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#071525" Offset="0"/>
                <GradientStop Color="#03070F" Offset="0.72"/>
                <GradientStop Color="#010309" Offset="1"/>
            </LinearGradientBrush>

            <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#123452" Offset="0"/>
                <GradientStop Color="#0A1B2D" Offset="0.55"/>
                <GradientStop Color="#131100" Offset="1"/>
            </LinearGradientBrush>

            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            </Style>

            <Style x:Key="TitleText" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="37"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            </Style>

            <Style x:Key="PageTitle" TargetType="TextBlock">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="24"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style x:Key="SmallHint" TargetType="TextBlock">
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                <Setter Property="TextWrapping" Value="Wrap"/>
            </Style>

            <Style x:Key="LabelText" TargetType="TextBlock">
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                <Setter Property="Margin" Value="0,10,0,5"/>
            </Style>

            <Style x:Key="Panel" TargetType="Border">
                <Setter Property="Background" Value="#0A1D30"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="18"/>
            </Style>

            <Style x:Key="Card" TargetType="Border">
                <Setter Property="Background" Value="#0F263A"/>
                <Setter Property="BorderBrush" Value="#255B7D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="10"/>
                <Setter Property="Padding" Value="18"/>
            </Style>

            <Style x:Key="FlatButton" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="Background" Value="#17486C"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush2}"/>
                <Setter Property="BorderThickness" Value="1.5"/>
                <Setter Property="Padding" Value="18,10"/>
                <Setter Property="Margin" Value="0,0,10,10"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#21608C"/>
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#0F334D"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.45"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
                <Setter Property="Foreground" Value="#08111B"/>
                <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush2}"/>
            </Style>

            <Style x:Key="OperationButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Padding" Value="16,10"/>
                <Setter Property="Margin" Value="0,0,0,8"/>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Background" Value="#163A58"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush2}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="MinHeight" Value="38"/>
                <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
            </Style>

            <Style TargetType="ComboBoxItem">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Background" Value="#102A40"/>
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#1F5E88"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#255F84"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Foreground" Value="#7F9DB3"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ComboDropDownToggle" TargetType="ToggleButton">
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="ClickMode" Value="Press"/>
                <Setter Property="Background" Value="#17486C"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush2}"/>
                <Setter Property="BorderThickness" Value="1,0,0,0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Border x:Name="ArrowBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                <Path Fill="{StaticResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M 0 0 L 8 0 L 4 5 Z"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ArrowBorder" Property="Background" Value="#21608C"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ArrowBorder" Property="Background" Value="#0F334D"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ComboBox">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="Background" Value="#163A58"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush2}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="MinHeight" Value="42"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Border x:Name="OuterBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" SnapsToDevicePixels="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="40"/>
                                        </Grid.ColumnDefinitions>

                                        <ContentPresenter x:Name="ContentSite"
                                                          Grid.Column="0"
                                                          Margin="12,0,8,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          IsHitTestVisible="False"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}" TextElement.Foreground="{TemplateBinding Foreground}"/>

                                        <TextBox x:Name="PART_EditableTextBox"
                                                 Grid.Column="0"
                                                 Margin="8,2,6,2"
                                                 Background="Transparent"
                                                 Foreground="{TemplateBinding Foreground}"
                                                 BorderThickness="0"
                                                 Padding="4,7"
                                                 FontFamily="{TemplateBinding FontFamily}"
                                                 FontSize="{TemplateBinding FontSize}"
                                                 FontWeight="{TemplateBinding FontWeight}"
                                                 CaretBrush="{StaticResource AccentBrush}"
                                                 VerticalContentAlignment="Center"
                                                 Visibility="Hidden"/>

                                        <ToggleButton Grid.Column="1"
                                                      Style="{StaticResource ComboDropDownToggle}"
                                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"/>
                                    </Grid>
                                </Border>

                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Focusable="False"
                                       Placement="Bottom"
                                       PopupAnimation="Slide"
                                       IsOpen="{TemplateBinding IsDropDownOpen}">
                                    <Grid MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}" MaxHeight="420">
                                        <Border Background="#102A40" BorderBrush="{StaticResource LineBrush2}" BorderThickness="1" CornerRadius="6">
                                            <ScrollViewer Margin="1" SnapsToDevicePixels="True">
                                                <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained"/>
                                            </ScrollViewer>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="OuterBorder" Property="Background" Value="#1D4C70"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                    <Setter TargetName="OuterBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="OuterBorder" Property="Background" Value="#1D4C70"/>
                                </Trigger>
                                <Trigger Property="IsEditable" Value="True">
                                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="OuterBorder" Property="Opacity" Value="0.55"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="FontSize" Value="16"/>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="Background" Value="#061321"/>
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="GridLinesVisibility" Value="Horizontal"/>
                <Setter Property="HorizontalGridLinesBrush" Value="#1B3C55"/>
                <Setter Property="VerticalGridLinesBrush" Value="#1B3C55"/>
                <Setter Property="RowBackground" Value="#0A1D30"/>
                <Setter Property="AlternatingRowBackground" Value="#0E2438"/>
                <Setter Property="HeadersVisibility" Value="Column"/>
                <Setter Property="RowHeaderWidth" Value="0"/>
                <Setter Property="FontSize" Value="15"/>
                <Setter Property="RowHeight" Value="42"/>
            </Style>

            <Style TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="#123A58"/>
                <Setter Property="Foreground" Value="{StaticResource AccentBrush2}"/>
                <Setter Property="BorderBrush" Value="#266486"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="16"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Padding" Value="10,9"/>
            </Style>

            <Style TargetType="DataGridCell">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
                <Setter Property="BorderBrush" Value="#1B3C55"/>
                <Setter Property="Padding" Value="8"/>
                <Style.Triggers>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#1E6E9A"/>
                        <Setter Property="Foreground" Value="#FFFFFF"/>
                    </Trigger>
                </Style.Triggers>
            </Style>


            <Style x:Key="PageOnlyTabControl" TargetType="{x:Type TabControl}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabControl}">
                            <Border x:Name="ContentFrame"
                                    Background="#071827"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="2"
                                    CornerRadius="0,0,10,10"
                                    Padding="22"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="PART_SelectedContentHost"
                                                  ContentSource="SelectedContent"
                                                  RecognizesAccessKey="True"
                                                  Margin="0"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FolderTab" TargetType="{x:Type RadioButton}">
                <Setter Property="Width" Value="270"/>
                <Setter Property="Height" Value="58"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                <Setter Property="Background" Value="#0D263B"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type RadioButton}">
                            <Grid ClipToBounds="False" SnapsToDevicePixels="True">
                                <Border x:Name="TabBox"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="2,2,2,2"
                                        CornerRadius="8,8,0,0"
                                        Padding="16,0,16,0"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter HorizontalAlignment="Stretch"
                                                      VerticalAlignment="Stretch"
                                                      RecognizesAccessKey="True"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="TabBox" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                    <Setter Property="Foreground" Value="#061321"/>
                                    <Setter Property="Panel.ZIndex" Value="20"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsChecked" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="TabBox" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="FolderTabHeaderText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
                <Setter Property="TextTrimming" Value="None"/>
            </Style>

            <Style x:Key="StepTabControl" TargetType="{x:Type TabControl}">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabControl}">
                            <Grid ClipToBounds="False" SnapsToDevicePixels="True">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>

                                <!-- Folder headers sit directly on the page frame. -->
                                <TabPanel x:Name="HeaderPanel"
                                          Grid.Row="0"
                                          Panel.ZIndex="5"
                                          IsItemsHost="True"
                                          KeyboardNavigation.TabIndex="1"
                                          Margin="0,0,0,-2"/>

                                <!-- Full active-page frame. Top border connects to the tabs; right side stays visible. -->
                                <Border x:Name="ContentFrame"
                                        Grid.Row="1"
                                        Panel.ZIndex="1"
                                        Margin="0,0,0,0"
                                        Background="#071827"
                                        BorderBrush="{StaticResource LineBrush}"
                                        BorderThickness="2"
                                        CornerRadius="0,0,10,10"
                                        Padding="22"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter x:Name="PART_SelectedContentHost"
                                                      ContentSource="SelectedContent"
                                                      RecognizesAccessKey="True"
                                                      Margin="0"/>
                                </Border>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="StepTab" TargetType="{x:Type TabItem}">
                <Setter Property="Width" Value="270"/>
                <Setter Property="Height" Value="58"/>
                <Setter Property="Margin" Value="0,0,12,0"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type TabItem}">
                            <Border x:Name="TabBox"
                                    Background="#0D263B"
                                    BorderBrush="{StaticResource LineBrush}"
                                    BorderThickness="2,2,2,2"
                                    CornerRadius="8,8,0,0"
                                    Padding="16,0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter ContentSource="Header"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="TabBox" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                    <Setter Property="Foreground" Value="#061321"/>
                                    <Setter Property="Panel.ZIndex" Value="10"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                </Trigger>
                                <MultiTrigger>
                                    <MultiTrigger.Conditions>
                                        <Condition Property="IsSelected" Value="True"/>
                                        <Condition Property="IsMouseOver" Value="True"/>
                                    </MultiTrigger.Conditions>
                                    <Setter TargetName="TabBox" Property="Background" Value="{StaticResource AccentBrush}"/>
                                    <Setter TargetName="TabBox" Property="BorderBrush" Value="{StaticResource LineBrush}"/>
                                </MultiTrigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="TabHeaderText" TargetType="TextBlock">
                <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TabItem}}"/>
                <Setter Property="FontFamily" Value="{StaticResource GameFontFamily}"/>
                <Setter Property="FontWeight" Value="Black"/>
                <Setter Property="FontSize" Value="17"/>
                <Setter Property="TextWrapping" Value="NoWrap"/>
                <Setter Property="TextTrimming" Value="None"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
